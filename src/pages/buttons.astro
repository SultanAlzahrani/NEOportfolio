---
import Layout from "../layouts/Layout.astro";
import CopyButton from "../components/CopyButton.svelte";
import EightyEightyThirtyOne from "../components/88x31.svelte";
---

<Layout>
  <section
    class="mb-0! transition-[translate,opacity] duration-300 delay-100 starting:opacity-0 starting:translate-y-4 text-[0.938rem] [&_img]:w-[88px] [&_img]:h-[31px]"
  >
    <legend>buttons</legend>

    <p class="mb-1">
      Here's a collection of 88x31 buttons i took from some fellas around the
      good old world wide web. I have to say that i don't know them personally,
      so content may vary. Get my button below:
    </p>

    <div class="flex max-md:flex-col">
      <a
        href="https://sultanonline.app/"
        target="_blank"
        class="shrink-0 mt-2 mr-2 h-min"
        ><img src="/88x31.gif" width="88" height="31" alt="trafficlunar" /></a
      >

      <div
        class="bg-mantle p-2.5 rounded-lg relative border border-surface0/75 shadow-sm mt-2"
      >
        <CopyButton client:load />

        <code class="text-sm font-mono" style="font-variant-ligatures: none;">
          <span class="text-teal">{"<"}</span><span class="text-blue">a</span>
          <span class="text-yellow">href</span><span class="text-teal">=</span
          ><span class="text-green">{'"https://sultanonline.app/"'}</span>
          <span class="text-yellow">target</span><span class="text-teal">=</span
          ><span class="text-green">{'"_blank"'}</span><span class="text-teal"
            >{"><"}</span
          ><span class="text-blue">img</span>
          <span class="text-yellow">src</span><span class="text-teal">=</span
          ><span class="text-green"
            >{'"https://api.sultanonline.app/media/88x31.gif"'}</span
          >
          <span class="text-yellow">alt</span><span class="text-teal">=</span
          ><span class="text-green">{'"sultanonline"'}</span>
          <span class="text-teal">{"/></"}</span><span class="text-blue">a</span
          ><span class="text-teal">{">"}</span>
        </code>
      </div>
    </div>

    <EightyEightyThirtyOne />
  </section>
</Layout>

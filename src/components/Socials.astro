---
import GitHubIcon from "../assets/icons/socials/github.svg";
import BlueskyIcon from "../assets/icons/socials/bluesky.svg";
import RedditIcon from "../assets/icons/socials/reddit.svg";
import DiscordIcon from "../assets/icons/socials/discord.svg";
import TwitterIcon from "../assets/icons/socials/twitter.svg";
import AniListIcon from "../assets/icons/socials/anilist.svg";
import LastFMIcon from "../assets/icons/socials/lastfm.svg";
import MailIcon from "../assets/icons/socials/mail.svg";
---

<section class="side p-2!">
  <legend>socials</legend>
  <ul
    class="grid grid-cols-4 [&_a]:flex [&_a]:justify-center [&_a]:size-full [&_a]:py-1"
  >
    <!-- z-50 for tooltips -->
    <li class="z-50">
      <a
        href="https://github.com/SultanAlzahrani"
        data-tooltip="GitHub"
        target="_blank"
        aria-label="GitHub"><GitHubIcon /></a
      >
    </li>
    <li class="z-50">
      <a
        href=""
        data-tooltip="No Bluesky Currently"
        target="_blank"
        aria-label="Bluesky"><BlueskyIcon /></a
      >
    </li>
    <li class="z-50">
      <a
        href="https://x.com/CEO_allegations"
        data-tooltip="Twitter"
        target="_blank"
        aria-label="Twitter"><TwitterIcon /></a
      >
    </li>
    <li class="z-50">
      <a
        href=""
        data-tooltip="No Discord yet"
        target="_blank"
        aria-label="Discord"><DiscordIcon /></a
      >
    </li>
    <li>
      <a
        href=""
        data-tooltip="No Reddit yet"
        target="_blank"
        aria-label="Reddit"><RedditIcon /></a
      >
    </li>
    <li>
      <a
        href="https://myanimelist.net/profile/WatcherOfArt"
        data-tooltip="AniList"
        target="_blank"
        aria-label="AniList"><AniListIcon /></a
      >
    </li>
    <li>
      <a
        href="https://www.last.fm/user/sultanooo"
        data-tooltip="Last.FM"
        target="_blank"
        aria-label="Last.FM"><LastFMIcon /></a
      >
    </li>
    <li>
      <a
        href="mailto:hello@sultanalzahranics@gmail.com"
        data-tooltip="Email"
        aria-label="Email"><MailIcon /></a
      >
    </li>
  </ul>
</section>
